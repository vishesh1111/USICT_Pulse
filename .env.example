# ── EmailJS Configuration ──────────────────────────────────────────
# 1. Go to https://www.emailjs.com → create a free account
# 2. Add an Email Service (Gmail recommended) → copy Service ID
# 3. Create an Email Template with these variables:
#    - {{to_email}}  → recipient's email
#    - {{to_name}}   → recipient's name
#    - {{subject}}   → email subject line
#    - {{message}}   → email body (HTML supported)
# 4. Copy the Template ID
# 5. Go to Account → General → copy your Public Key
# 6. Paste all three values below and rename this file to .env.local

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
